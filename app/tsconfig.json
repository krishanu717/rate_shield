{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "outDir": "./dist",
    "rootDir": "./",

    "baseUrl": ".",
    "paths": {
      "@libs/*": ["libs/*"]
    },

    "types": ["node"],
    "moduleResolution": "node",

    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    "strict": true,
    "skipLibCheck": true,

    "ignoreDeprecations": "6.0"
  },
  "include": ["apps/**/*", "libs/**/*"]
}
